from kivymd.app import MDApp
import sqlite3
from datetime import datetime

# ---------------- DATABASE SERVICE ----------------

class Database:

    def __init__(self):
        self.conn = sqlite3.connect("biscoito.db")
        self.cursor = self.conn.cursor()
        self.create_tables()

    def create_tables(self):

        self.cursor.execute("""
        CREATE TABLE IF NOT EXISTS vendas(
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            data TEXT,
            produto TEXT,
            quantidade INTEGER,
            valor REAL
        )
        """)

        self.cursor.execute("""
        CREATE TABLE IF NOT EXISTS gastos(
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            data TEXT,
            descricao TEXT,
            valor REAL
        )
        """)

        self.conn.commit()

    # ---------- VENDAS ----------

    def add_venda(self, produto, quantidade, valor):

        data = datetime.now().strftime("%d/%m/%Y")

        self.cursor.execute(
            "INSERT INTO vendas (data, produto, quantidade, valor) VALUES (?, ?, ?, ?)",
            (data, produto, quantidade, valor),
        )

        self.conn.commit()

    # ---------- GASTOS ----------

    def add_gasto(self, descricao, valor):

        data = datetime.now().strftime("%d/%m/%Y")

        self.cursor.execute(
            "INSERT INTO gastos (data, descricao, valor) VALUES (?, ?, ?)",
            (data, descricao, valor),
        )

        self.conn.commit()

    # ---------- RELATORIO ----------

    def get_totais(self):

        self.cursor.execute("SELECT SUM(valor) FROM vendas")
        vendas = self.cursor.fetchone()[0] or 0

        self.cursor.execute("SELECT SUM(valor) FROM gastos")
        gastos = self.cursor.fetchone()[0] or 0

        lucro = vendas - gastos

        return vendas, gastos, lucro


# ---------------- SCREENS ----------------

class MenuScreen(Screen):
    pass


class VendaScreen(Screen):

    def salvar(self):

        produto = self.ids.produto.text
        quantidade = self.ids.quantidade.text
        valor = self.ids.valor.text

        if produto and quantidade and valor:

            app.db.add_venda(produto, int(quantidade), float(valor))

            self.ids.produto.text = ""
            self.ids.quantidade.text = ""
            self.ids.valor.text = ""


class GastoScreen(Screen):

    def salvar(self):

        descricao = self.ids.descricao.text
        valor = self.ids.valor.text

        if descricao and valor:

            app.db.add_gasto(descricao, float(valor))

            self.ids.descricao.text = ""
            self.ids.valor.text = ""


class RelatorioScreen(Screen):

    def on_pre_enter(self):

        vendas, gastos, lucro = app.db.get_totais()

        self.ids.vendas.text = f"Vendas: R$ {vendas:.2f}"
        self.ids.gastos.text = f"Gastos: R$ {gastos:.2f}"
        self.ids.lucro.text = f"Lucro: R$ {lucro:.2f}"


